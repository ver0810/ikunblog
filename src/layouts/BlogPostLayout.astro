---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const { frontmatter, headings } = Astro.props;
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{frontmatter.title} - IKUNBLOG</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  </head>
  <body>
    <div class="page-container">
      <div class="content-wrap">
        <div class="animated-background"></div>
        
        <!-- 主题切换按钮 -->
        <button id="theme-toggle" class="theme-toggle" aria-label="切换主题">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" id="moon-icon"></path>
            <circle cx="12" cy="12" r="5" id="sun-circle"></circle>
            <line x1="12" y1="1" x2="12" y2="3" id="sun-line-1"></line>
            <line x1="12" y1="21" x2="12" y2="23" id="sun-line-2"></line>
            <line x1="4.22" y1="4.22" x2="5.64" y2="5.64" id="sun-line-3"></line>
            <line x1="18.36" y1="18.36" x2="19.78" y2="19.78" id="sun-line-4"></line>
            <line x1="1" y1="12" x2="3" y2="12" id="sun-line-5"></line>
            <line x1="21" y1="12" x2="23" y2="12" id="sun-line-6"></line>
            <line x1="4.22" y1="19.78" x2="5.64" y2="18.36" id="sun-line-7"></line>
            <line x1="18.36" y1="5.64" x2="19.78" y2="4.22" id="sun-line-8"></line>
          </svg>
        </button>
        
        <header class="glass-effect">
          <div class="container">
            <h1>IKUNBLOG</h1>
            <nav>
              <ul>
                <li><a href="/">首页</a></li>
                <li><a href="/blog">博客</a></li>
                <li><a href="/about">关于</a></li>
              </ul>
            </nav>
          </div>
        </header>

        <main class="blog-post-container">
          <!-- 左侧边栏：文章列表 -->
          <aside class="sidebar left-sidebar glass-effect">
            <h3>博客文章</h3>
            <ul class="post-list">
              <li><a href="/posts/post-1/" class={frontmatter.title.includes("第一篇") ? "active" : ""}>我的第一篇博客文章</a></li>
              <li><a href="/posts/post-2/" class={frontmatter.title.includes("第二篇") ? "active" : ""}>我的第二篇博客文章</a></li>
              <li><a href="/posts/post-3/" class={frontmatter.title.includes("第三篇") ? "active" : ""}>我的第三篇博客文章</a></li>
            </ul>
          </aside>
          
          <!-- 中间内容：文章正文 -->
          <article class="blog-content glass-container">
            <div class="post-header">
              {frontmatter.image && (
                <div class="featured-image">
                  <img src={frontmatter.image.url} alt={frontmatter.image.alt} />
                </div>
              )}
              <h1>{frontmatter.title}</h1>
              <div class="post-meta">
                <span class="date">发布于: {new Date(frontmatter.pubDate).toLocaleDateString('zh-CN')}</span>
                <span class="author">作者: {frontmatter.author}</span>
              </div>
              <div class="tags">
                {frontmatter.tags && frontmatter.tags.map((tag) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
            </div>
            
            <div class="post-body">
              <slot />
            </div>
          </article>
          
          <!-- 右侧边栏：文章目录 -->
          <aside class="sidebar right-sidebar glass-effect">
            <h3>文章目录</h3>
            <nav class="table-of-contents">
              <ul>
                {headings.map((heading) => (
                  <li class={`level-${heading.depth}`}>
                    <a href={`#${heading.slug}`}>{heading.text}</a>
                  </li>
                ))}
              </ul>
            </nav>
          </aside>
        </main>
      </div>

      <footer class="glass-effect">
        <div class="container">
          <p>&copy; {new Date().getFullYear()} IKUN博客</p>
        </div>
      </footer>
    </div>

    <script>
      // 主题切换逻辑
      document.addEventListener('DOMContentLoaded', function() {
        const themeToggle = document.getElementById('theme-toggle');
        const body = document.body;
        
        // 加载保存的主题
        const savedTheme = localStorage.getItem('theme') || 'light';
        if (savedTheme === 'dark') {
          body.classList.add('dark-theme');
          themeToggle.classList.add('dark');
        }
        
        themeToggle.addEventListener('click', () => {
          // 切换主题类
          body.classList.toggle('dark-theme');
          themeToggle.classList.toggle('dark');
          
          // 保存当前主题设置
          const currentTheme = body.classList.contains('dark-theme') ? 'dark' : 'light';
          localStorage.setItem('theme', currentTheme);
        });
      });
    </script>

    <style>
      /* 页面容器样式，确保footer在底部 */
      .page-container {
        display: flex;
        flex-direction: column;
        min-height: 100vh; /* 视口高度 */
      }
      
      .content-wrap {
        flex: 1; /* 占用剩余空间 */
      }
      
      /* 布局样式 */
      .blog-post-container {
        display: grid;
        grid-template-columns: 250px 1fr 250px;
        gap: 1.5rem;
        max-width: 1400px;
        margin: 2rem auto;
        padding: 0 1rem;
      }
      
      /* 侧边栏样式 */
      .sidebar {
        padding: 1.5rem;
        height: fit-content;
        position: sticky;
        top: 100px;
      }
      
      .sidebar h3 {
        margin-bottom: 1rem;
        font-size: 1.3rem;
        color: var(--color-primary);
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        padding-bottom: 0.5rem;
      }
      
      /* 文章列表样式 */
      .post-list {
        list-style: none;
        padding: 0;
      }
      
      .post-list li {
        margin-bottom: 0.8rem;
      }
      
      .post-list a {
        color: var(--text-color);
        text-decoration: none;
        transition: color 0.3s ease;
        display: block;
        padding: 0.5rem;
        border-radius: 8px;
      }
      
      .post-list a:hover, .post-list a.active {
        background: rgba(255, 255, 255, 0.1);
        color: var(--color-primary);
      }
      
      /* 文章目录样式 */
      .table-of-contents ul {
        list-style: none;
        padding: 0;
      }
      
      .table-of-contents li {
        margin-bottom: 0.5rem;
      }
      
      .table-of-contents a {
        color: var(--text-color);
        text-decoration: none;
        transition: color 0.3s ease;
        display: block;
        padding: 0.25rem 0;
      }
      
      .table-of-contents a:hover {
        color: var(--color-primary);
      }
      
      .level-1 {
        font-weight: bold;
      }
      
      .level-2 {
        padding-left: 1rem;
        font-size: 0.95rem;
      }
      
      .level-3 {
        padding-left: 2rem;
        font-size: 0.9rem;
      }
      
      /* 文章内容样式 */
      .blog-content {
        padding: 2rem;
        line-height: 1.8;
      }
      
      .post-header {
        margin-bottom: 2rem;
      }
      
      .featured-image {
        margin-bottom: 1.5rem;
        overflow: hidden;
        border-radius: var(--border-radius);
      }
      
      .featured-image img {
        width: 100%;
        height: auto;
        object-fit: cover;
      }
      
      .post-header h1 {
        font-size: 2.5rem;
        margin-bottom: 1rem;
        color: var(--color-primary);
      }
      
      .post-meta {
        display: flex;
        gap: 1rem;
        margin-bottom: 1rem;
        color: var(--text-color-soft);
      }
      
      .tags {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
        margin-bottom: 1.5rem;
      }
      
      .tag {
        display: inline-block;
        padding: 0.25rem 0.75rem;
        background: rgba(255, 255, 255, 0.1);
        color: var(--color-primary);
        border-radius: 50px;
        font-size: 0.85rem;
      }
      
      .post-body {
        font-size: 1.1rem;
      }
      
      .post-body h1, .post-body h2, .post-body h3, 
      .post-body h4, .post-body h5, .post-body h6 {
        margin-top: 2rem;
        margin-bottom: 1rem;
        color: var(--color-primary);
      }
      
      .post-body p {
        margin-bottom: 1rem;
      }
      
      .post-body ul, .post-body ol {
        margin-bottom: 1rem;
        padding-left: 1.5rem;
      }
      
      .post-body li {
        margin-bottom: 0.5rem;
      }
      
      .post-body img {
        max-width: 100%;
        border-radius: 8px;
      }
      
      .post-body blockquote {
        border-left: 4px solid var(--color-primary);
        padding-left: 1rem;
        font-style: italic;
        margin: 1.5rem 0;
      }
      
      .post-body pre {
        background: rgba(0, 0, 0, 0.2);
        padding: 1rem;
        border-radius: 8px;
        overflow-x: auto;
        margin: 1.5rem 0;
      }
      
      .post-body code {
        background: rgba(0, 0, 0, 0.2);
        padding: 0.2rem 0.4rem;
        border-radius: 4px;
        font-size: 0.9rem;
      }
      
      /* 页脚样式 */
      footer {
        margin-top: auto; /* 推到容器底部 */
        width: 100%;
      }
      
      /* 响应式布局 */
      @media (max-width: 1100px) {
        .blog-post-container {
          grid-template-columns: 200px 1fr 200px;
        }
      }
      
      @media (max-width: 900px) {
        .blog-post-container {
          grid-template-columns: 1fr;
        }
        
        .sidebar {
          position: static;
          margin-bottom: 1rem;
        }
        
        .left-sidebar {
          order: 1;
        }
        
        .blog-content {
          order: 0;
        }
        
        .right-sidebar {
          order: 2;
        }
      }
      
      #moon-icon {
        display: none;
      }
      
      .theme-toggle.dark #sun-circle,
      .theme-toggle.dark [id^="sun-line"] {
        display: none;
      }
      
      .theme-toggle.dark #moon-icon {
        display: block;
      }
      
      /* 主题切换按钮 */
      .theme-toggle {
        position: fixed;
        bottom: 20px;
        right: 20px;
        width: 50px;
        height: 50px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        z-index: 1000;
        transition: transform 0.3s ease;
        background: var(--glass-background);
        backdrop-filter: var(--glass-backdrop);
        -webkit-backdrop-filter: var(--glass-backdrop);
        border: var(--glass-border);
        box-shadow: var(--card-shadow);
      }
      
      .theme-toggle:hover {
        transform: scale(1.1);
      }
      
      .theme-toggle svg {
        width: 24px;
        height: 24px;
        color: var(--text-color);
        transition: transform 0.5s ease;
      }
      
      .theme-toggle.dark svg {
        transform: rotate(180deg);
      }
    </style>
  </body>
</html>