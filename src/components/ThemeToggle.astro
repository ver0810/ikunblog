---
---
<button id="theme-toggle" class="theme-toggle" aria-label="切换主题">
  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" id="moon-icon"></path>
    <circle cx="12" cy="12" r="5" id="sun-circle"></circle>
    <line x1="12" y1="1" x2="12" y2="3" id="sun-line-1"></line>
    <line x1="12" y1="21" x2="12" y2="23" id="sun-line-2"></line>
    <line x1="4.22" y1="4.22" x2="5.64" y2="5.64" id="sun-line-3"></line>
    <line x1="18.36" y1="18.36" x2="19.78" y2="19.78" id="sun-line-4"></line>
    <line x1="1" y1="12" x2="3" y2="12" id="sun-line-5"></line>
    <line x1="21" y1="12" x2="23" y2="12" id="sun-line-6"></line>
    <line x1="4.22" y1="19.78" x2="5.64" y2="18.36" id="sun-line-7"></line>
    <line x1="18.36" y1="5.64" x2="19.78" y2="4.22" id="sun-line-8"></line>
  </svg>
</button>

<style>
  #moon-icon {
    display: none;
  }
  
  .theme-toggle.dark #sun-circle,
  .theme-toggle.dark [id^="sun-line"] {
    display: none;
  }
  
  .theme-toggle.dark #moon-icon {
    display: block;
  }
</style>

<script>
  // 主题切换逻辑
  const themeToggle = document.getElementById('theme-toggle');
  const body = document.body;
  
  // 加载保存的主题
  const savedTheme = localStorage.getItem('theme') || 'light';
  if (savedTheme === 'dark') {
    body.classList.add('dark-theme');
    themeToggle.classList.add('dark');
  }
  
  themeToggle.addEventListener('click', () => {
    // 切换主题类
    body.classList.toggle('dark-theme');
    themeToggle.classList.toggle('dark');
    
    // 保存当前主题设置
    const currentTheme = body.classList.contains('dark-theme') ? 'dark' : 'light';
    localStorage.setItem('theme', currentTheme);
  });
</script>